METHOD constructor.

  carrier_id    = i_carrier_id.
  connection_id = i_connection_id.
  flight_date   = i_flight_date.

  DATA flight_raw TYPE st_flights_buffer.

  TRY.

      flight_raw =
        flights_buffer[
          carrier_id    = i_carrier_id
          connection_id = i_connection_id
          flight_date   = i_flight_date ].

    CATCH cx_sy_itab_line_not_found.

      SELECT SINGLE
        FROM /lrn/passflight
        FIELDS plane_type_id,
               seats_max,
               seats_occupied,
               price,
               currency_code
        WHERE carrier_id    = @i_carrier_id
          AND connection_id = @i_connection_id
          AND flight_date   = @i_flight_date
        INTO CORRESPONDING FIELDS OF @flight_raw.

      IF sy-subrc <> 0.
        RETURN.
      ENDIF.

      APPEND flight_raw TO flights_buffer.

  ENDTRY.

  plane_type_id  = flight_raw-plane_type_id.
  seats_max      = flight_raw-seats_max.
  seats_occupied = flight_raw-seats_occupied.
  price          = flight_raw-price.
  currency_code  = flight_raw-currency_code.

ENDMETHOD.
